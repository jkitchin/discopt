/course/

# Build output
_build/

# Task files
tasks.org

# LaTeX build artifacts
manuscript/_minted/
manuscript/*.aux
manuscript/*.bbl
manuscript/*.bcf
manuscript/*.blg
manuscript/*.dvi
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.log
manuscript/*.out
manuscript/*.run.xml
manuscript/*.synctex.gz
manuscript/*.toc
# discopt.tex is generated from discopt.org via `scimax export discopt.org --format pdf`
manuscript/discopt.tex

# Claude Code
.claude/

# Crucible knowledge base: track the wiki and bib, exclude generated /
# copyrighted / transient artifacts.
.crucible/crucible.db
.crucible/references.bib.lock
.crucible/sources/external/
.crucible/wiki/viz.html

# Adversary test runs
adversary/

# Jupyter Book
docs/_build/

# DoE demo workbook artifacts
docs/notebooks/*.xlsx

# Solver-written .sol files (POUNCE / AMPL solvers like couenne/scip write a
# <stub>.sol next to the input .nl when run over the vendored instance tree).
# These are run artifacts, never fixtures (0 are tracked) — keep them out.
*.sol

# stray solver listing files (GAMS/BARON .lst) — not part of the repo
*.lst

# scratchpad run logs (keep the harnesses, drop the outputs)
scratchpad/*_out*.txt
scratchpad/*.log
